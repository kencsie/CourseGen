# CourseGen — server-side configuration
#
# Phase 1 之後，OpenRouter API Key、Tavily Key、以及所有模型名稱都改由
# 使用者在 UI 中設定，會儲存在瀏覽器 localStorage，**不要**寫在這個檔案。
# 以下 env 只給 admin 調整。

# OpenRouter API base URL（一般不需要改）
BASE_URL=https://openrouter.ai/api/v1

# Workflow 參數
MAX_ITERATIONS=5
CONTENT_MAX_RETRIES=5

# Langfuse 可觀測性（選填）
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# 資料庫連線字串（Phase 2 之後預設 local Postgres）
# 本機開發起 PG：
#   docker run -d --name coursegen-pg \
#     -e POSTGRES_USER=coursegen -e POSTGRES_PASSWORD=changeme \
#     -e POSTGRES_DB=coursegen -p 5432:5432 \
#     -v coursegen-pg-data:/var/lib/postgresql/data postgres:16-alpine
DATABASE_URL=postgresql://coursegen:changeme@localhost:5432/coursegen
# SQLite fallback（legacy，不建議新環境用）：
# DATABASE_URL=sqlite:///data/coursegen.db
